// New model: deliverables and link/file attachments.
model ClientDeliverableDraft {
  id                   String   @id @default(cuid())
  clientOrganizationId String
  projectId            String?
  taskId               String?
  title                String
  description          String?
  url                  String?
  fileObjectKey        String?
  mimeType             String?
  sizeBytes            Int?
  status               String   @default("READY_FOR_REVIEW") // DeliverableStatus in real migration
  visibility           String   @default("CLIENT_VISIBLE") // ClientVisibility in real migration
  uploadedByUserId     String?
  approvedByUserId     String?
  approvedAt           DateTime?
  revisionRequestedAt  DateTime?
  revisionReason       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([clientOrganizationId])
  @@index([projectId])
  @@index([taskId])
  @@index([status])
}

// New model: client-safe activity feed separate from raw internal ActivityLog.
model ClientActivityEventDraft {
  id                   String   @id @default(cuid())
  clientOrganizationId String
  projectId            String?
  taskId               String?
  actorUserId          String?
  eventType            String
  visibility           String   @default("CLIENT_VISIBLE") // ClientVisibility in real migration
  summary              String
  metadata             Json?
  createdAt            DateTime @default(now())

  @@index([clientOrganizationId, createdAt])
  @@index([projectId])
  @@index([taskId])
}

// Migration strategy:
// 1. Create ClientOrganization records from existing Client.name rows.
// 2. Backfill Project.clientOrganizationId by matching Project.client to ClientOrganization.legacyClientName.
// 3. Backfill Task.clientOrganizationId from Task.client or parent Project.clientOrganizationId.
// 4. Keep legacy Project.client and Task.client as denormalized display/fallback fields for one release.
// 5. Convert client-facing reads to require clientOrganizationId.
// 6. Create ClientTaskRequest for all new client intake; convert approved requests into Task.
// 7. Remove legacy free-text client dependency after all records are backfilled.
