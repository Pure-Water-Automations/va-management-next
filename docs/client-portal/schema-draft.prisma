// New model: deliverables and link/file attachments.
model ClientDeliverableDraft {
  id        String   @id @default(cuid())
  clientOrganizationId String
  projectId String?
  taskId    String?
  title     String
  description String?
  url       String?
  fileObjectKey String?
  mimeType  String?
  sizeBytes Int?
  status    String   @default("ready_for_review")
  visibility String  @default("client_visible")
  uploadedByUserId String?
  approvedByUserId String?
  approvedAt DateTime?
  revisionRequestedAt DateTime?
  revisionReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientOrganizationId])
  @@index([projectId])
  @@index([taskId])
  @@index([status])
}

// New model: client-safe activity feed separate from raw internal ActivityLog.
model ClientActivityEventDraft {
  id        String   @id @default(cuid())
  clientOrganizationId String
  projectId String?
  taskId    String?
  actorUserId String?
  eventType String
  visibility String @default("client_visible")
  summary String
  metadata Json?
  createdAt DateTime @default(now())

  @@index([clientOrganizationId, createdAt])
  @@index([projectId])
  @@index([taskId])
}

