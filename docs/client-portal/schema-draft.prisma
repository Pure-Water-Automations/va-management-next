// New model: canonical external customer/account.
model ClientOrganizationDraft {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  status       String   @default("ACTIVE") // ClientOrgStatus in real migration
  primaryEmail String?
  logoUrl      String?
  brandColor   String?
  packageTier  String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Replace existing free-text Client usage over time.
  legacyClientName String? @unique

  @@index([status])
}

// New model: which users belong to which client orgs.
model ClientMembershipDraft {
  id                   String   @id @default(cuid())
  clientOrganizationId String
  userId               String
  role                 String   @default("MEMBER") // ClientMembershipRole in real migration
  active               Boolean  @default(true)
  invitedByUserId      String?
  invitedAt            DateTime?
  acceptedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Real migration should use relations:
  // clientOrganization ClientOrganization @relation(fields: [clientOrganizationId], references: [id], onDelete: Cascade)
  // user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientOrganizationId, userId])
  @@index([userId])
  @@index([clientOrganizationId, active])
}

// New model: request-first client intake.
// Client submissions should land here first, then Team Leaders/Admins convert
// approved requests into real Task rows. This prevents client intake from
// immediately assigning a VA or triggering assignment emails.
model ClientTaskRequestDraftModel {
  id                   String   @id @default(cuid())
  clientOrganizationId String
  requestedByUserId    String
  projectId            String?
  createdTaskId        String?
  status               String   @default("RECEIVED") // ClientTaskRequestStatus in real migration
  visibility           String   @default("CLIENT_VISIBLE") // ClientVisibility in real migration
  title                String
  desiredOutcome       String
  priority             String   @default("Medium")
  dueDate              DateTime?
  links                String?
  clientNotes          String?
  suggestedAssigneeId  String?
  approvalRequired     Boolean  @default(false)
  triagedByUserId      String?
  triagedAt            DateTime?
  declinedReason       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([clientOrganizationId, status])
  @@index([requestedByUserId])
  @@index([projectId])
  @@index([createdTaskId])
}

