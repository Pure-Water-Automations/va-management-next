[Unit]
Description=PWA OS Hub TEST instance (dev-projects.pwasecondbrain.uk, DB va_console_hub)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
WorkingDirectory=/app/SecondBrain/va-projects-console/current
EnvironmentFile=/app/SecondBrain/va-projects-console/shared/.env.production
# Shared OpenRouter key (Purii extraction). Optional (-): unit still starts if absent.
EnvironmentFile=-/etc/secondbrain/openrouter.env
# Loopback only: reachable solely via the Cloudflare tunnel hostname.
# Test instance rule: the web app ONLY — never install the va-management-* timers
# against va_console_hub (one worker fleet per real database).
ExecStart=/usr/bin/node /app/SecondBrain/va-projects-console/current/node_modules/next/dist/bin/next start -H 127.0.0.1 -p 8801
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
