// Notion two-way sync (beta). One connection per client org points at that
// client's own Notion workspace (an internal integration token they share with
// a Projects and/or Tasks database). Status syncs both directions; everything
// else stays in Notion, reachable via the page link in the item description.
model NotionConnection {
  id                   String   @id @default(cuid())
  clientOrganizationId String   @unique
  token                String // Notion integration token (secret) — never returned to the client
  projectsDatabaseId   String? // raw Notion database id the user connected
  projectsDataSourceId String? // resolved data_source id used for queries/creates
  tasksDatabaseId      String?
  tasksDataSourceId    String?
  statusProperty       String   @default("Status") // the Notion property name synced both ways
  statusMap            Json? // { project: { Planning: "Not started", ... }, task: { NotStarted: "...", ... } }
  active               Boolean  @default(true)
  createdByEmail       String?
  lastSyncedAt         DateTime?
  lastEditedCursor     String? // ISO high-water mark of the newest Notion last_edited_time seen
  lastSyncSummary      Json? // counts from the most recent poll (imported/updated/pushed/errors)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  clientOrganization ClientOrganization @relation(fields: [clientOrganizationId], references: [id], onDelete: Cascade)

  @@index([active])
}

model ClientTaskRequest {
  id                   String                  @id @default(cuid())
  title                String
  description          String
  priorityPreference   Priority                @default(Medium)
  dueDatePreference    DateTime?
  fileReference        String?
  status               ClientTaskRequestStatus @default(RECEIVED)
  submittedById        String
  clientOrganizationId String
  assignedTaskId       String?                 @unique
  declineReason        String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  submittedBy          User                    @relation("ClientTaskRequestSubmitter", fields: [submittedById], references: [id])
  clientOrganization   ClientOrganization      @relation(fields: [clientOrganizationId], references: [id])
  assignedTask         Task?                   @relation("ClientTaskRequestTask", fields: [assignedTaskId], references: [id])

  @@index([clientOrganizationId])
  @@index([status])
  @@index([submittedById])
}

// ── Client sales & onboarding ──────────────────────────────────────────────
// The closing seam of the sales SOP, brought in-app: a Deal (mirror of the
// Notion Pipeline) drives a client service agreement (in-app e-sign, reusing the
// recruitment signer), payment (Stripe), client-org creation, and onboarding.
// Top-of-funnel (lead capture, qualification, discovery) stays in Notion.

enum DealStage {
  new
  discovery_scheduled
  discovery_completed
  proposal_needed
  proposal_sent
  negotiation
  verbal_yes
  won
  lost
  nurture
  no_show
}

model Deal {
  id                String              @id @default(cuid())
  notionPageId      String?             @unique // link back to the Pipeline Tracking page
  orgName           String
  contactName       String?
  contactEmail      String?
  source            String?
  // ── Native discovery funnel: public intake (Phase 1) ──────────────────
  discoveryJson      Json?     // full raw /discover answers (source of truth)
  teamSize           String?
  missionStatement   String?
  hoursPerWeek       String?   // band: "Under 5" | "5–10" | "10–20" | "20+"
  budgetAvailable    String?   // "yes" | "unsure" | "no"
  timeline           String?
  painTags           Json?     // string[]
  triedBefore        String?
  heardAbout         String?
  estimatedAdminCost Int?      // computed cost-of-inaction figure ($/yr)
  fitVerdict         String?   // pre-AI heuristic: "hot" | "warm" | "cold"
  // ── AI lead scoring (mirrors Candidate.screen*) ───────────────────────
  leadVerdict        String?   // "hot" | "warm" | "cold"
  leadScore          Int?      // 0–100
  leadSummary        String?
  leadFlags          Json?     // string[]
  scoredAt           DateTime?
  // ── Native discovery-call booking (Phase 2) ───────────────────────────
  discoveryCallAt       DateTime?
  discoveryCallEndAt    DateTime?
  discoveryCallToken    String?   @unique // magic link: book / reschedule / cancel
  discoveryCallStatus   String?   // "scheduled" | "completed" | "no_show" | "cancelled"
  discoveryCallVideoUrl String?
  discoveryRepEmail     String?   // rep whose slot was chosen (= accountOwnerEmail)
  discoveryReminderSentAt DateTime? // set once the pre-call reminder has gone out
  // ── Discovery-call notes (Phase 3): structured capture from the call ──
  discoveryNotesJson    Json?
  // ── Google Calendar event (gcal integration) ─────────────────────────
  discoveryCalEventId   String?   // GCal event id — patch on reschedule, delete on cancel
  discoveryCalId        String?   // which calendar the event lives on (rep's calendarId)
  accountOwnerEmail String?
  stage             DealStage           @default(new)
  packageName       String?
  dealValue         Float?
  billingType       String? // retainer | hourly | project
  startDate         DateTime?
  // Special-deal review (Team Lead gate from the sales SOP)
  reviewNeeded      Boolean             @default(false)
  reviewApproved    Boolean             @default(false)
  reviewNotes       String?
  // Sales-to-onboarding handoff summary (the SOP block), captured as structured JSON
  handoffSummary    Json?
  lostReason        String?
  nextFollowUpAt    DateTime?
  lastContactAt     DateTime?
  clientOrgId       String?             @unique // set when Won → client org created
  clientOrg         ClientOrganization? @relation(fields: [clientOrgId], references: [id])
  agreement         ClientAgreement?
  wonAt              DateTime? // stamped once when the deal first hits "won"
  upgradeOfAccountId String? // set on upgrade deals: the ClientAccount being grown
  discoveryZoomMeetingId String? // Zoom meeting backing the discovery call (join link is discoveryCallVideoUrl)
  attachmentKeys     Json                @default("[]") // R2 keys of lead-attached files: discovery/{dealId}/…
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([stage])
  @@index([nextFollowUpAt])
  @@index([discoveryCallStatus, discoveryCallAt])
}

/// Per-rep Google Calendar credential for discovery-call booking (freebusy +
/// event create/update/delete). Tokens stored in-DB like NotionConnection; the
/// google-auth-library OAuth2 client auto-refreshes from refreshToken.
model CalendarConnection {
  id           String    @id @default(cuid())
  repEmail     String    @unique // lowercased rep identity (= Deal.discoveryRepEmail)
  calendarId   String    @default("primary")
  clientId     String
  clientSecret String
  refreshToken String
  accessToken  String?
  tokenUri     String?
  expiryDate   BigInt? // ms epoch
  scope        String?
  email        String? // authorizing Google account (from userinfo)
  active       Boolean   @default(true)
  createdByEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum ClientAgreementStatus {
  draft
  sent
  viewed
  signed
  paid
  active
  void
}

model ClientAgreement {
  id                   String                @id @default(cuid())
  dealId               String                @unique
  deal                 Deal                  @relation(fields: [dealId], references: [id])
  signToken            String?               @unique // single-use signing credential
  status               ClientAgreementStatus @default(draft)
  packageName          String?
  priceLabel           String? // e.g. "$1,200/mo, billed in advance"
  billingType          String? // retainer | hourly | project
  deadline             DateTime?
  // signature / audit (mirrors ContractSignature)
  sentAt               DateTime?
  signedAt             DateTime?
  signerName           String?
  signerEmail          String?
  signerIp             String?
  userAgent            String?
  signatureImage       String?               @db.Text
  termsHash            String?
  pdfDriveFileId       String?
  pdfWebViewLink       String?
  // payment (Stripe)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeInvoiceId      String?
  paidAt               DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

enum ClientOnboardingStatus {
  pending
  in_progress
  completed
}

// ── AI CFO ────────────────────────────────────────────────────────────────
// One row per pushed CFO snapshot (from the Mac-side analyst/skill via the
// machine-to-machine /api/cfo/snapshot endpoint). `payload` is the whole POST
// body (derived tables + optional executive narrative + actions). QuickBooks is
// never touched by this app — only derived, read-only JSON crosses the wire.
// Pruned to the last 60 rows on insert (trend history).
model CfoSnapshot {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  computedAt   DateTime // when analyst.js computed the numbers (from the payload)
  hasNarrative Boolean  @default(false) // true = full review (skill); false = nightly derived-only
  payload      Json
  @@index([createdAt])
}

model ClientOnboarding {
  id                   String                 @id @default(cuid())
  clientOrganizationId String                 @unique
  clientOrganization   ClientOrganization     @relation(fields: [clientOrganizationId], references: [id])
  owner                String? // onboarding owner email
  intakeToken          String?                @unique // public intake-form credential
  intakeJson           Json? // submitted intake answers
  intakeReceivedAt     DateTime?
  status               ClientOnboardingStatus @default(pending)
  // checklist (from the Onboarding SOP + sales handoff)
  intakeReceived       Boolean                @default(false)
  onboardingCallBooked Boolean                @default(false)
  onboardingCallDone   Boolean                @default(false)
  driveFolderCreated   Boolean                @default(false)
  portalAccessGranted  Boolean                @default(false)
  commsCadenceSet      Boolean                @default(false)
  firstWeekPriorities  Boolean                @default(false)
  vaAssigned           Boolean                @default(false)
  kickoffRecapSent     Boolean                @default(false)
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

