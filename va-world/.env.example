# ── va-world server ────────────────────────────────────────────────────────
# Port the Colyseus server listens on.
PORT="2567"

# Base URL of the VA management app that exposes /api/external/va-profile.
# Leave blank in pure local dev to make every avatar a guest.
MANAGER_BASE_URL="http://localhost:3032"

# Shared secret for the manager's /api/external bridge (must match the value
# set as EXTERNAL_APP_SECRET in the management app's env).
EXTERNAL_APP_SECRET=""

# Dev-only fallback identity when there is no Cloudflare Access header and no
# ?email= join option. Leave blank in production.
DEV_FALLBACK_EMAIL=""

# CORS allow-list for the HTTP matchmaking endpoint. Use the client origin in
# dev (e.g. http://localhost:5180) or "*". In prod the client is same-origin.
ALLOWED_ORIGIN="*"

# LiveKit Cloud — proximity audio/video (Phase 3). Leave blank to disable media
# (the world still works; the A/V overlay stays hidden). Create a project at
# https://cloud.livekit.io to get the URL + API key/secret.
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# ── va-world client (Vite, build-time) ─────────────────────────────────────
# Override the WebSocket endpoint. Defaults to ws://<host>:2567 when unset.
VITE_WORLD_WS_URL=""
