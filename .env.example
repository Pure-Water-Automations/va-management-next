# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://va_console:change-me@localhost:5432/va_console"

# ── App ───────────────────────────────────────────────────────────────────
APP_BASE_URL="http://localhost:3032"
# Dev-only: auto-signed-in identity when there is no Cloudflare Access header.
DEV_AUTH_EMAIL="okamotomiak@gmail.com"

# ── Google service account (sheet read/import + mirror write) ──────────────
# Provide ONE of these. JSON is the full service-account key as a string.
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SERVICE_ACCOUNT_FILE=""

# Live legacy workbook to import current data FROM (one-time + parity checks).
SOURCE_SHEET_ID="1_a0V3skXADkSgK2Lqf5yFdDVzshhPkGzYQSwU-CKxKM"

# NEW dedicated mirror spreadsheet to export Postgres TO (read-only for humans).
MIRROR_SHEET_ID=""

# Public job-application Google Form response sheet (polled for intake).
APPLICATION_RESPONSES_SHEET_ID=""
APPLICATION_RESPONSES_TAB="Form Responses 1"

# ── External app bridge (e.g. va-world) ────────────────────────────────────
# Shared secret for trusted server-to-server callers of the read-only
# /api/external/* endpoints. The caller sends `Authorization: Bearer <secret>`.
# Leave blank to disable the bridge (all /api/external/* calls return 401).
# Endpoints: GET /api/external/va-profile?email= (one VA) and
# GET /api/external/roster (active-VA directory for the va-world teammate list).
# NOTE: /api/external/* must be added to the Cloudflare Access BYPASS list
# (like /apply and /sign) since these are service calls with no Access session.
EXTERNAL_APP_SECRET=""

# ── Email (Workspace Gmail send) ───────────────────────────────────────────
# Path to the Workspace OAuth token json on the VPS (gmail.send capable).
# The from-address is configurable at runtime via the Setting `system_email_from`.
GOOGLE_WORKSPACE_TOKEN_FILE="/root/.google_workspace_mcp/credentials/okamotomiak@gmail.com.json"

# ── Stripe (client sales payments) ─────────────────────────────────────────
# Optional. Used by the client sales flow to take first payment after a service
# agreement is signed. Leave blank to disable Stripe — payment then falls back to
# the manual "Mark paid" button in the sales board.
#   STRIPE_SECRET_KEY      — sk_live_… / sk_test_… (server-side; never exposed)
#   STRIPE_WEBHOOK_SECRET  — whsec_…; the /api/stripe/webhook route is DISABLED
#                            (503) until this is set, and rejects unverified events.
# NOTE: /api/stripe/webhook must be reachable without a login session (it's a
# top-level public route; add to the Cloudflare Access BYPASS list if Access is on).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Feature flags / deployment profile ─────────────────────────────────────
# These split a STAGING box (beta on) from the official PRODUCTION box (beta off).
#
# FOUNDER_EMAILS — comma-separated allow-list for founder-only beta features
#   (Enhance with Second Brain, Discover). Defaults to the founders when unset.
#   The production/official deployment sets this EMPTY ("") so those features are
#   hidden from everyone.
# FOUNDER_EMAILS=""
#
# RECORDINGS_ENABLED — the Loom-style screen recorder + library. Default ON.
#   isRecordingsVisible() is admin-OR-founder, so emptying FOUNDER_EMAILS alone is
#   NOT enough to hide it from admins. Set "false" on the production/official
#   deployment to fully exclude the recorder (pages 404, nav hidden, and the
#   create/finalize/enhance/delete/review/update APIs 404 even for admins). The
#   client-portal "Video Updates" view/comment path stays available regardless.
# RECORDINGS_ENABLED="false"

# ── Notion two-way sync — one-click "Connect with Notion" (OPTIONAL) ──────────
# Without these, the connect UI falls back to the manual integration-token flow.
# To enable the OAuth button:
#   1. Notion → My integrations (notion.so/my-integrations) → New integration →
#      type "Public". Fill name/logo. Under "Capabilities" allow read+update content.
#   2. Add the redirect URI (must match exactly):
#        https://dev-team.pwasecondbrain.uk/api/notion/oauth/callback
#   3. Copy the OAuth client ID + client secret into the two vars below.
# The token Notion returns is stored per-client in NotionConnection.token and used
# exactly like an internal-integration token. Redirect URI defaults to
# ${APP_BASE_URL}/api/notion/oauth/callback when NOTION_OAUTH_REDIRECT_URI is unset.
NOTION_OAUTH_CLIENT_ID=""
NOTION_OAUTH_CLIENT_SECRET=""
NOTION_OAUTH_REDIRECT_URI=""
